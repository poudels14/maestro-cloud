{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["services"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "services": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/service"
      }
    }
  },
  "$defs": {
    "service": {
      "type": "object",
      "required": ["name", "deploy"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "provider": {
          "type": "string",
          "enum": ["docker", "shell"],
          "default": "docker"
        },
        "build": {
          "$ref": "#/$defs/build"
        },
        "image": {
          "type": "string"
        },
        "deploy": {
          "$ref": "#/$defs/deploy"
        },
        "ingress": {
          "$ref": "#/$defs/ingress"
        }
      },
      "oneOf": [
        {
          "required": ["build"],
          "properties": {
            "image": false
          }
        },
        {
          "required": ["image"],
          "properties": {
            "build": false
          }
        },
        {
          "properties": {
            "provider": { "const": "shell" }
          },
          "required": ["deploy"]
        }
      ]
    },
    "build": {
      "type": "object",
      "required": ["repo", "dockerfilePath"],
      "additionalProperties": false,
      "properties": {
        "repo": {
          "type": "string"
        },
        "branch": {
          "type": "string"
        },
        "dockerfilePath": {
          "type": "string"
        },
        "watch": {
          "type": "boolean",
          "default": false
        },
        "env": {
          "$ref": "#/$defs/envConfig"
        }
      }
    },
    "deploy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "flags": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "exposePorts": {
          "type": "array",
          "items": { "type": "integer", "minimum": 1, "maximum": 65535 },
          "default": []
        },
        "command": {
          "$ref": "#/$defs/command"
        },
        "healthcheckPath": {
          "type": "string"
        },
        "replicas": {
          "type": "integer",
          "minimum": 1,
          "default": 1
        },
        "maxRestarts": {
          "type": "integer",
          "minimum": 0
        },
        "env": {
          "$ref": "#/$defs/envConfig"
        },
        "secrets": {
          "type": "object",
          "required": ["mountPath"],
          "additionalProperties": false,
          "properties": {
            "mountPath": { "type": "string" },
            "source": {
              "type": "string",
              "description": "Load all key/value pairs from a secret provider (e.g. aws-secret://secret-name)"
            },
            "items": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            }
          }
        }
      }
    },
    "command": {
      "type": "object",
      "required": ["command"],
      "additionalProperties": false,
      "properties": {
        "command": {
          "type": "string"
        },
        "args": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    },
    "envConfig": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source": {
          "type": "string",
          "description": "Load all key/value pairs from a secret provider (e.g. aws-secret://secret-name)"
        },
        "items": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "ingress": {
      "type": "object",
      "required": ["host"],
      "additionalProperties": false,
      "properties": {
        "host": {
          "type": "string"
        },
        "port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        }
      }
    }
  }
}
